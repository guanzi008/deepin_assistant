{
  "name": "deepin-assistant",
  "private": true,
  "version": "0.1.0",
  "description": "deepin / UOS 桌面助手，处理邮件整理、系统诊断、外设连接和常见修复动作。",
  "author": "guanzi008",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.mjs",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:4173 tcp:4174 && ORBIT_SKIP_INTERNAL_API=1 electron .",
    "dev:desktop": "concurrently -k \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:electron\"",
    "desktop": "npm run build && ORBIT_DESKTOP_DIST=1 electron .",
    "build": "vite build",
    "build:desktop": "npm run build && electron-builder --linux dir",
    "pack:linux": "npm run build && electron-builder --linux AppImage",
    "preview": "vite preview",
    "start:api": "node server/index.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.19",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "cc.odata.orbit.deepinassistant",
    "productName": "Orbit Deepin Assistant",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "server/**/*"
    ],
    "linux": {
      "target": [
        "dir",
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
